# Receipt fiscal-core — environment (copy to .env; never commit .env)

# --- Service ---
ENV=sandbox                 # sandbox | prod
LOG_LEVEL=info
SECRETS_BACKEND=env         # env | aws
AWS_REGION=eu-central-1

# --- Database (Postgres) ---
# Local docker-compose uses host "db"; for host runs use localhost.
DATABASE_URL=postgresql+psycopg://receipt:receipt@localhost:5432/receipt

# --- Delta (merchant #1) sandbox credentials ---
# Pulled from the Delta EC2 box:
#   site_config.json -> client id / secret / api key / vat number / base url
#   /home/frappe/deltaspmu/eims/ -> private_key.key + certificate.pem
DELTA_EIMS_BASE_URL=https://core.mor.gov.et
DELTA_EIMS_CLIENT_ID=
DELTA_EIMS_CLIENT_SECRET=
DELTA_EIMS_API_KEY=
DELTA_EIMS_VAT_NUMBER=43256663343256663322
DELTA_EIMS_DEFAULT_BUYER_ID=3333367896666
# Absolute paths to the cert + key files on this machine (chmod 600 the key):
DELTA_EIMS_PRIVATE_KEY_PATH=./secrets/delta/private_key.key
DELTA_EIMS_CERT_PATH=./secrets/delta/certificate.pem
